# Copia este archivo como .env y ajusta los valores

# URL para MIGRACIONES (usuario postgres, todos los permisos)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/atenza"

# URL para la API en runtime (rol restringido, D-10)
APP_DATABASE_URL="postgresql://atenza_app:atenza_app_dev@localhost:5433/atenza"

# Servidor
PORT=3000

# URL base para los enlaces de correos (apuntará al frontend web)
APP_URL="http://localhost:3000"

# Cuenta admin creada por el seed
ADMIN_EMAIL="admin@atenza.com"
ADMIN_PASSWORD="admin12345"

# JWT (HU-33 / D-03) — genera un secreto largo y aleatorio para producción
JWT_SECRET="cambia-este-secreto-en-produccion"
JWT_EXPIRES_DOCENTE="8h"
JWT_EXPIRES_ESTUDIANTE="30d"

# Correo (verificación de email, recuperar contraseña). Vacío en local:
# los correos solo se imprimen en la consola (ConsolaEmailService), no
# hace falta llenarlo para desarrollar. En producción, credenciales SMTP
# de tu proveedor (recomendado: Resend, resend.com — 3,000 correos/mes
# gratis; también sirve con Mailgun, SES o cualquier SMTP genérico).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="Atenza <no-responde@tu-dominio.com>"
